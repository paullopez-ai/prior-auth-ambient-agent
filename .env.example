# Demo Track (set both to true; no GCP calls)
MOCK_LLM=true
MOCK_BQ=true

# Pub/Sub emulator (demo track)
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=demo-project

# Live GCP track (set MOCK_LLM=false MOCK_BQ=false and fill these)
GCP_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash

# Server ports
SUBSCRIBER_PORT=8080
REVIEW_API_PORT=8081

# Pipeline tuning
CONFIDENCE_THRESHOLD=0.80
